# Copy this file to .env and fill in the values before running locally.
# Never commit .env to version control.

# Server
PORT=8080

# Database (Postgres)
DATABASE_URL=postgres://thethinker:thethinker@localhost:5433/thethinker?sslmode=disable

# JWT signing secret — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# AI service
AI_SERVICE_URL=http://localhost:8001

# Anthropic API key — required for AI outfit recommendations.
# Get one at https://console.anthropic.com/ (free tier available).
# Leave unset to run the app without AI features; the recommendation
# endpoint will return a clear error instead of crashing.
# ANTHROPIC_API_KEY=sk-ant-...

# Google Cloud Storage — image uploads
# Production: set GCS_BUCKET and GOOGLE_APPLICATION_CREDENTIALS
GCS_BUCKET=wardrobe-images
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Local development: use fake-gcs-server emulator
# Run: docker run -p 4443:4443 fsouza/fake-gcs-server
# Then set:
# GCS_EMULATOR_HOST=localhost:4443

# Weather API — OpenWeatherMap (https://openweathermap.org/api)
# Get a free API key at https://home.openweathermap.org/users/sign_up
# Accepts city name ("London") or ZIP/postcode ("10001" or "SW1A 1AA,GB").
# Leave unset to disable live weather: the badge shows the last-known-good
# cached reading (if any, within max-age) and is otherwise omitted entirely.
# WEATHER_API_KEY=your_openweathermap_api_key_here

# TODO: Google Calendar OAuth
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# TODO: Datadog (not yet wired)
# DD_SERVICE=thethinker-api
# DD_ENV=development
# DD_VERSION=0.1.0
