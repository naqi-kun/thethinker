# Copy this file to .env and fill in the values before running locally.
# Never commit .env to version control.

# Server
PORT=8080

# Database (Postgres — not yet connected, see CLAUDE.md)
DATABASE_URL=postgres://thethinker:thethinker@localhost:5433/thethinker?sslmode=disable

# TODO: Weather API (provider TBD)
# WEATHER_API_KEY=

# TODO: Google Calendar OAuth
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# TODO: Apple Calendar OAuth
# APPLE_OAUTH_CLIENT_ID=
# APPLE_OAUTH_CLIENT_SECRET=

# JWT signing secret — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# MinIO (local S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=thethinker
MINIO_SECRET_KEY=thethinker
MINIO_BUCKET=wardrobe-images
MINIO_USE_SSL=false

# TODO: Datadog (not yet wired)
# DD_SERVICE=thethinker-api
# DD_ENV=development
# DD_VERSION=0.1.0
