# Copy this file to .env and fill in the values before running locally.
# Never commit .env to version control.

# Server
PORT=8080

# Database (Postgres)
DATABASE_URL=postgres://thethinker:thethinker@localhost:5433/thethinker?sslmode=disable

# JWT signing secret — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# AI service
AI_SERVICE_URL=http://localhost:8001

# Google Cloud Storage — image uploads
# Production: set GCS_BUCKET and GOOGLE_APPLICATION_CREDENTIALS
GCS_BUCKET=wardrobe-images
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Local development: use fake-gcs-server emulator
# Run: docker run -p 4443:4443 fsouza/fake-gcs-server
# Then set:
# GCS_EMULATOR_HOST=localhost:4443

# TODO: Weather API (provider TBD)
# WEATHER_API_KEY=

# TODO: Google Calendar OAuth
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# TODO: Datadog (not yet wired)
# DD_SERVICE=thethinker-api
# DD_ENV=development
# DD_VERSION=0.1.0
